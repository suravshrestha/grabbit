{
  "name": "grabbit",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:extension": "pnpm --filter @grabbit/extension dev",
    "dev:desktop": "pnpm --filter @grabbit/desktop tauri dev",
    "build:extension": "pnpm --filter @grabbit/extension build",
    "build:desktop": "pnpm --filter @grabbit/desktop tauri build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "node --import tsx ./node_modules/prettier/bin/prettier.cjs --write .",
    "test": "pnpm -r test --if-present",
    "typecheck": "pnpm -r typecheck",
    "prepare": "husky",
    "fetch-binaries": "tsx scripts/fetch-binaries.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "eslint": "^9.20.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-sonarjs": "^3.0.2",
    "eslint-plugin-unicorn": "^56.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1"
  }
}
