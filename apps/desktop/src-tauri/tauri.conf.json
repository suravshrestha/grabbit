{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grabbit",
  "version": "0.1.0",
  "identifier": "com.grabbit.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Grabbit",
        "width": 420,
        "height": 600,
        "resizable": false
      }
    ],
    "security": {
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/*"],
    "externalBin": ["resources/yt-dlp", "resources/ffmpeg"],
    "icon": ["icons/icon.png"]
  }
}
